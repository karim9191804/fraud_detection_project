{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🚀 Fraud Detection Training on Kaggle GPU P100\n",
    "\n",
    "Ce notebook s'exécute sur Kaggle avec GPU P100 pour entraîner le modèle GNN+LLM+RLHF"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Vérifier le GPU disponible\n",
    "!nvidia-smi\n",
    "\n",
    "import torch\n",
    "print(f\"\\nPyTorch version: {torch.__version__}\")\n",
    "print(f\"CUDA available: {torch.cuda.is_available()}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"CUDA version: {torch.version.cuda}\")\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    print(f\"GPU Memory: {torch.cuda.get_device_properties(0).total_memory / 1e9:.2f} GB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Installation des dépendances\n",
    "!pip install -q torch-geometric torch-scatter torch-sparse\n",
    "!pip install -q transformers peft trl accelerate\n",
    "!pip install -q wandb PyGithub gitpython\n",
    "!pip install -q python-dotenv pyyaml loguru\n",
    "\n",
    "print(\"✅ Dépendances installées\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cloner le code depuis GitHub\n",
    "import os\n",
    "from git import Repo\n",
    "\n",
    "# REMPLACEZ par votre repo\n",
    "GITHUB_REPO = \"votre-username/fraud-detection-project\"\n",
    "GITHUB_TOKEN = \"ghp_your_token_here\"  # Ou utilisez Kaggle Secrets\n",
    "\n",
    "repo_url = f\"https://{GITHUB_TOKEN}@github.com/{GITHUB_REPO}.git\"\n",
    "\n",
    "if os.path.exists('fraud-detection-project'):\n",
    "    !rm -rf fraud-detection-project\n",
    "\n",
    "print(\"📥 Clonage du repository...\")\n",
    "Repo.clone_from(repo_url, 'fraud-detection-project')\n",
    "print(\"✅ Repository cloné\")\n",
    "\n",
    "os.chdir('fraud-detection-project')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Configuration pour utiliser GPU P100\n",
    "import yaml\n",
    "\n",
    "with open('configs/config.yaml', 'r') as f:\n",
    "    config = yaml.safe_load(f)\n",
    "\n",
    "# Optimisation GPU\n",
    "config['dataset']['batch_size'] = 256  # Plus grand batch pour P100\n",
    "config['dataset']['num_workers'] = 4\n",
    "config['gnn']['hidden_channels'] = 512  # Plus de capacité\n",
    "config['fine_tuning']['gradient_accumulation_steps'] = 2\n",
    "\n",
    "# Sauvegarder\n",
    "with open('configs/config.yaml', 'w') as f:\n",
    "    yaml.dump(config, f)\n",
    "\n",
    "print(\"✅ Configuration optimisée pour GPU P100\")\n",
    "print(f\"  - Batch size: {config['dataset']['batch_size']}\")\n",
    "print(f\"  - Hidden channels: {config['gnn']['hidden_channels']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Charger les données IEEE-CIS depuis Kaggle\n",
    "print(\"📊 Les données IEEE-CIS sont déjà disponibles dans Kaggle Input\")\n",
    "!ls -lh /kaggle/input/ieee-fraud-detection/\n",
    "\n",
    "# Créer liens symboliques\n",
    "!mkdir -p data/raw/ieee-fraud\n",
    "!ln -sf /kaggle/input/ieee-fraud-detection/* data/raw/ieee-fraud/"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Préparation des données\n",
    "import sys\n",
    "sys.path.insert(0, '.')\n",
    "\n",
    "from src.data.ieee_dataset import prepare_ieee_dataset\n",
    "\n",
    "print(\"🔧 Préparation des données...\")\n",
    "dataset = prepare_ieee_dataset(\n",
    "    data_dir='data/raw/ieee-fraud',\n",
    "    output_dir='data/processed',\n",
    "    test_size=0.15,\n",
    "    val_size=0.15\n",
    ")\n",
    "\n",
    "print(\"\\n✅ Données préparées:\")\n",
    "for split, data in dataset.items():\n",
    "    print(f\"  {split}: {data.num_nodes} nodes, {data.num_edges} edges\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Créer le modèle sur GPU\n",
    "from src.models.hybrid_model import create_hybrid_model\n",
    "\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "print(f\"\\n🖥️  Device: {device}\")\n",
    "\n",
    "gnn_config = {\n",
    "    \"in_channels\": 432,\n",
    "    \"hidden_channels\": 512,  # Optimisé pour P100\n",
    "    \"num_layers\": 3,\n",
    "    \"dropout\": 0.3,\n",
    "    \"model_type\": \"GAT\"  # GAT pour meilleure performance\n",
    "}\n",
    "\n",
    "llm_config = {\n",
    "    \"model_name\": \"microsoft/phi-2\",\n",
    "    \"max_length\": 512,\n",
    "    \"temperature\": 0.7,\n",
    "    \"use_lora\": True,\n",
    "    \"lora_r\": 16,\n",
    "    \"lora_alpha\": 32\n",
    "}\n",
    "\n",
    "print(\"\\n🧠 Création du modèle GNN+LLM...\")\n",
    "model = create_hybrid_model(gnn_config, llm_config)\n",
    "model = model.to(device)\n",
    "\n",
    "print(\"✅ Modèle créé et déplacé sur GPU\")\n",
    "print(f\"  Total parameters: {sum(p.numel() for p in model.parameters()):,}\")\n",
    "print(f\"  Trainable parameters: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Configuration WandB (optionnel)\n",
    "import wandb\n",
    "\n",
    "# Utilisez Kaggle Secrets pour WANDB_API_KEY\n",
    "try:\n",
    "    from kaggle_secrets import UserSecretsClient\n",
    "    user_secrets = UserSecretsClient()\n",
    "    wandb_key = user_secrets.get_secret(\"WANDB_API_KEY\")\n",
    "    wandb.login(key=wandb_key)\n",
    "    \n",
    "    wandb.init(\n",
    "        project=\"fraud-detection-kaggle\",\n",
    "        name=f\"kaggle-p100-{pd.Timestamp.now().strftime('%Y%m%d_%H%M')}\",\n",
    "        config={\n",
    "            \"device\": device,\n",
    "            \"gpu\": torch.cuda.get_device_name(0) if torch.cuda.is_available() else \"cpu\",\n",
    "            \"batch_size\": config['dataset']['batch_size'],\n",
    "            \"gnn_type\": gnn_config['model_type']\n",
    "        }\n",
    "    )\n",
    "    print(\"✅ WandB activé\")\n",
    "except:\n",
    "    print(\"⚠️  WandB non configuré (optionnel)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Entraînement avec le système Jour/Nuit\n",
    "from src.training.day_night_trainer import DayNightTrainer\n",
    "from torch_geometric.loader import DataLoader\n",
    "\n",
    "# Créer le trainer\n",
    "trainer = DayNightTrainer(\n",
    "    model=model,\n",
    "    config=config,\n",
    "    device=device\n",
    ")\n",
    "\n",
    "# Data loaders optimisés pour GPU\n",
    "train_loader = DataLoader(\n",
    "    [dataset['train']],\n",
    "    batch_size=config['dataset']['batch_size'],\n",
    "    shuffle=True,\n",
    "    num_workers=0,  # Kaggle kernels: num_workers=0\n",
    "    pin_memory=True if device == \"cuda\" else False\n",
    ")\n",
    "\n",
    "val_loader = DataLoader(\n",
    "    [dataset['val']],\n",
    "    batch_size=config['dataset']['batch_size'],\n",
    "    shuffle=False,\n",
    "    num_workers=0,\n",
    "    pin_memory=True if device == \"cuda\" else False\n",
    ")\n",
    "\n",
    "test_loader = DataLoader(\n",
    "    [dataset['test']],\n",
    "    batch_size=config['dataset']['batch_size'],\n",
    "    shuffle=False,\n",
    "    num_workers=0,\n",
    "    pin_memory=True if device == \"cuda\" else False\n",
    ")\n",
    "\n",
    "print(\"\\n🚀 Démarrage de l'entraînement sur GPU P100...\")\n",
    "print(f\"  Train batches: {len(train_loader)}\")\n",
    "print(f\"  Val batches: {len(val_loader)}\")\n",
    "print(f\"  Test batches: {len(test_loader)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Phase 1: Mode JOUR - Inférence initiale\n",
    "print(\"\\n☀️ MODE JOUR - Inférence initiale\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "day_results = trainer.day_mode_inference(\n",
    "    train_loader,\n",
    "    save_critical=True\n",
    ")\n",
    "\n",
    "print(f\"\\n✅ Jour terminé:\")\n",
    "print(f\"  Transactions: {day_results['stats']['total_transactions']}\")\n",
    "print(f\"  Fraudes détectées: {day_results['stats']['fraud_detected']}\")\n",
    "print(f\"  Cas critiques: {day_results['stats']['critical_cases']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Phase 2: Mode NUIT - Fine-tuning + RLHF\n",
    "print(\"\\n🌙 MODE NUIT - Fine-tuning & RLHF\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "night_results = trainer.night_mode_training(\n",
    "    train_loader,\n",
    "    val_loader,\n",
    "    num_epochs=3  # Ajustez selon votre temps disponible\n",
    ")\n",
    "\n",
    "print(f\"\\n✅ Nuit terminée:\")\n",
    "print(f\"  Best val loss: {night_results['gnn_metrics']['best_val_loss']:.4f}\")\n",
    "print(f\"  Checkpoint: {night_results['checkpoint']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Phase 3: Mode MATIN - Validation finale\n",
    "print(\"\\n🌅 MODE MATIN - Validation finale\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "morning_results = trainer.morning_validation(\n",
    "    val_loader,\n",
    "    test_loader\n",
    ")\n",
    "\n",
    "print(f\"\\n✅ Validation terminée:\")\n",
    "print(f\"  Can deploy: {morning_results['can_deploy']}\")\n",
    "print(f\"\\nMétriques de validation:\")\n",
    "for metric, value in morning_results['val_metrics'].items():\n",
    "    if isinstance(value, float):\n",
    "        print(f\"  {metric}: {value:.4f}\")\n",
    "\n",
    "if morning_results['test_metrics']:\n",
    "    print(f\"\\nMétriques de test:\")\n",
    "    for metric, value in morning_results['test_metrics'].items():\n",
    "        if isinstance(value, float):\n",
    "            print(f\"  {metric}: {value:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sauvegarder le modèle entraîné\n",
    "import os\n",
    "\n",
    "os.makedirs('final_model', exist_ok=True)\n",
    "model.save_pretrained('final_model')\n",
    "\n",
    "print(\"💾 Modèle sauvegardé dans: final_model/\")\n",
    "print(\"\\n📁 Contenu:\")\n",
    "!ls -lh final_model/"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Push les résultats vers GitHub\n",
    "print(\"\\n📤 Push des résultats vers GitHub...\")\n",
    "\n",
    "from git import Repo\n",
    "from datetime import datetime\n",
    "\n",
    "try:\n",
    "    repo = Repo('.')\n",
    "    \n",
    "    # Ajouter les fichiers\n",
    "    repo.git.add('checkpoints/')\n",
    "    repo.git.add('logs/')\n",
    "    repo.git.add('memory/')\n",
    "    repo.git.add('final_model/')\n",
    "    \n",
    "    # Commit\n",
    "    commit_msg = f\"Kaggle P100 training - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\"\n",
    "    repo.index.commit(commit_msg)\n",
    "    \n",
    "    # Push\n",
    "    origin = repo.remote('origin')\n",
    "    origin.push()\n",
    "    \n",
    "    print(\"✅ Résultats poussés vers GitHub\")\n",
    "except Exception as e:\n",
    "    print(f\"⚠️  Erreur lors du push: {e}\")\n",
    "    print(\"Vous pouvez télécharger les fichiers manuellement depuis /kaggle/working/\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Résumé final\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"🎉 ENTRAÎNEMENT TERMINÉ !\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "print(\"\\n📊 Résumé:\")\n",
    "print(f\"  GPU utilisé: {torch.cuda.get_device_name(0)}\")\n",
    "print(f\"  Temps GPU: {torch.cuda.max_memory_allocated() / 1e9:.2f} GB max\")\n",
    "print(f\"  Modèle déployable: {'✅ OUI' if morning_results['can_deploy'] else '❌ NON'}\")\n",
    "\n",
    "print(\"\\n📁 Fichiers générés:\")\n",
    "print(\"  - checkpoints/: Checkpoints d'entraînement\")\n",
    "print(\"  - logs/: Logs et métriques\")\n",
    "print(\"  - memory/: Mémoire temporelle RLHF\")\n",
    "print(\"  - final_model/: Modèle final entraîné\")\n",
    "\n",
    "print(\"\\n🔗 Prochaines étapes:\")\n",
    "print(\"  1. Vérifier les résultats sur GitHub\")\n",
    "print(\"  2. Déployer sur Hugging Face Spaces\")\n",
    "print(\"  3. Tester l'interface Gradio\")\n",
    "print(\"  4. Collecter du feedback humain pour RLHF\")\n",
    "\n",
    "if wandb.run:\n",
    "    print(f\"\\n📈 WandB Run: {wandb.run.get_url()}\")\n",
    "    wandb.finish()"
   ]
  }
